DATABASE_URL=postgresql+asyncpg://vf:vf@localhost:5432/verifyflow

# LLM - change base_url to switch providers
# OpenRouter (any model):  https://openrouter.ai/api/v1
# OpenAI:                  https://api.openai.com/v1
# Ollama (local):          http://localhost:11434/v1
# Anthropic compat:        https://api.anthropic.com/v1
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=your-key-here
LLM_MODEL=anthropic/claude-sonnet-4-5
LLM_JUDGE_MODEL=anthropic/claude-sonnet-4-5

# MCP
GITHUB_TOKEN=your-github-token
GITHUB_OWNER=your-github-username

# Executor
MAX_RETRIES=3
VERIFICATION_CONFIDENCE_THRESHOLD=0.75
